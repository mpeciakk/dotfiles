/* Generated by update-colors.sh */
* {
    base: #1e1e2eaa;
    base-solid: #1e1e2e;
    surface: #313244aa;
    surface-solid: #313244;
    text: #cdd6f4;
    accent: #89b4fa;
    urgent: #f38ba8;
    result-color: #a6e3a1;

    font: "JetBrainsMono Nerd Font 12";
    radius-inner: 8px;
    radius-outer: 12px;
    padding-0: 16px;
    padding-1: 12px;
    padding-2: 10px;
    padding-3: 8px;
    border-size: 2px;

    background-color: @base;
    text-color: @text;
}
