.dotter/cache.toml
.dotter/local.toml
**/cookies.txt

# Generated by quickshell at runtime (symlink into its VFS); used as the qmlls
# project-root marker but not a committed file.
config/quickshell/.qmlls.ini

# Claude Code — never commit secrets or runtime/cache state.
# Only curated config sources live under .claude/ (see .dotter/global.toml).
.claude/.credentials.json
.claude/projects/
.claude/sessions/
.claude/session-env/
.claude/shell-snapshots/
.claude/file-history/
.claude/backups/
.claude/plans/
.claude/tasks/
.claude/jobs/
.claude/plugins/
.claude/daemon/
.claude/daemon.*
.claude/history.jsonl
.claude/*cache*
.claude/policy-limits.json
.claude/remote-settings.json
.claude/.last-cleanup
