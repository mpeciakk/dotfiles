window-rule {
  geometry-corner-radius 12

  clip-to-geometry true
}

window-rule {
    match title="^Open File.*$"
    match title="^Select a File.*$"
    match title="^Save As.*$"
    match title="^File Upload.*$"
    match title=".*wants to save$"
    match title=".*wants to open$"
    match title=".*Minecraft.*"

    open-floating true
}

window-rule {
    match app-id="1password"
    open-floating true
    open-focused true
    block-out-from "screencast"
}

// VRR only for games (output uses on-demand=true). niri has NO fullscreen matcher,
// and on-demand enables VRR whenever a matching window is merely *present* on the
// output — so we must match each game explicitly by app-id/title, never "all except".
// mpv and the browser are deliberately never matched here, so video never triggers
// VRR (this panel black-flashes on VRR refresh changes; 24/30fps video resyncs
// continuously). Add a game: run `niri msg windows` while it's open, add its app-id.
window-rule {
    match title=".*Minecraft.*"
    variable-refresh-rate true
}

layer-rule {
    match namespace="^quickshell-wallpaper$"
    place-within-backdrop true
}
