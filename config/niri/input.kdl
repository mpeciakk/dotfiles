input {
    keyboard {
        xkb {
            layout "pl"
        }
    }

    touchpad {
        natural-scroll
        scroll-factor 0.5
        accel-profile "flat"
        accel-speed -0.15
    }

    mouse {
        accel-speed -0.8
        accel-profile "flat"
    }

    focus-follows-mouse max-scroll-amount="95%"
}
